---
import '../styles/globals.css';
import Navbar from '../components/Navbar';
import Hero from '../components/Hero';
import StartSection from '../components/StartSection';
import EcosystemSection from '../components/EcosystemSection';
import Constellation from '../components/Constellation';
import CtaFooter from '../components/CtaFooter';
import PageBackground from '../components/PageBackground';

const title = 'CH5 LLC — Personal maker company';
const description = 'CH5 is a personal maker company building products, tools, and experiments. Firefly is the flagship — a privacy-first AI assistant.';
const backgroundVariant = 'fluid';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="bg-black text-white">
    <PageBackground client:only="react" variant={backgroundVariant} />
    <div class="relative z-10 isolate">
      <Navbar client:load />
      <Hero client:load />
      <div>
        <StartSection />
        <EcosystemSection />
        <Constellation />
        <CtaFooter />
      </div>
    </div>
  </body>
</html>
